{
    "name": "peterfox/arcana",
    "description": "Dynamic AI Agent Skill Loader — Extend agent knowledge on demand with progressive disclosure.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "ai",
        "agent",
        "skills",
        "llm",
        "tool-calling",
        "progressive-disclosure",
        "laravel"
    ],
    "authors": [
        {
            "name": "Peter Fox",
            "email": "peter.fox@peterfox.me"
        }
    ],
    "require": {
        "php": "^8.4",
        "psr/simple-cache": "^3.0",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "laravel/ai": "^0.6",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^11.0",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^11.0",
        "psalm/phar": "^5.26"
    },
    "suggest": {
        "laravel/ai": "Required for Laravel AI SDK tool integration"
    },
    "autoload": {
        "psr-4": {
            "PeterFox\\Arcana\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PeterFox\\Arcana\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PeterFox\\Arcana\\Laravel\\ArcanaServiceProvider"
            ],
            "aliases": {
                "Arcana": "PeterFox\\Arcana\\Laravel\\Facades\\Arcana"
            }
        }
    },
    "scripts": {
        "test": "phpunit --no-coverage",
        "test:coverage": "phpunit",
        "analyse": "phpstan analyse --no-progress",
        "lint": "pint",
        "lint:check": "pint --test",
        "check": [
            "@lint:check",
            "@analyse",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "test": "Run the PHPUnit test suite",
        "test:coverage": "Run tests with code coverage report",
        "analyse": "Run PHPStan static analysis (level 8)",
        "lint": "Fix code style with Laravel Pint",
        "lint:check": "Check code style without making changes (CI-safe)",
        "check": "Check style, run static analysis, then run tests"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
