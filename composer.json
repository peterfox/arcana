{
    "name": "peterfox/arcana",
    "description": "Dynamic AI Agent Skill Loader — Extend agent knowledge on demand with progressive disclosure.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "ai",
        "agent",
        "skills",
        "llm",
        "tool-calling",
        "progressive-disclosure",
        "laravel"
    ],
    "authors": [
        {
            "name": "Peter Fox",
            "email": "peter.fox@peterfox.me"
        }
    ],
    "require": {
        "php": "^8.4",
        "psr/simple-cache": "^3.0",
        "symfony/yaml": "^7.0 || ^8.0"
    },
    "require-dev": {
        "laravel/ai": "^0.6.3 || ^0.7.0",
        "laravel/pint": "^1.29.1",
        "league/flysystem": "^3.33",
        "league/flysystem-memory": "^3.31",
        "orchestra/testbench": "^11.1",
        "peterfox/phpstan-toon-formatter": "^1.1",
        "peterfox/phpunit-toon-result-printer": "^1.2",
        "phpstan/phpstan": "^2.1.51",
        "phpstan/phpstan-deprecation-rules": "^2.0.4",
        "phpunit/phpunit": "^11.5.55",
        "psalm/phar": "^5.26.1"
    },
    "suggest": {
        "laravel/ai": "Required for Laravel AI SDK tool integration",
        "league/flysystem": "Required for FlysystemSkillLibrary adapter"
    },
    "autoload": {
        "psr-4": {
            "PeterFox\\Arcana\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PeterFox\\Arcana\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PeterFox\\Arcana\\Laravel\\ArcanaServiceProvider"
            ],
            "aliases": {
                "Arcana": "PeterFox\\Arcana\\Laravel\\Facades\\Arcana"
            }
        }
    },
    "scripts": {
        "test": "phpunit --no-coverage",
        "test:coverage": "phpunit",
        "analyse": "phpstan analyse --no-progress",
        "lint": "pint",
        "lint:check": "pint --test",
        "check": [
            "@lint:check",
            "@analyse",
            "@test"
        ],
        "check:ai": [
            "printf 'lint:'",
            "@lint:ai",
            "printf '\\nphpstan:'",
            "@analyse:ai",
            "printf '\\ntests:'",
            "@test:ai"
        ],
        "lint:ai": "pint --format=agent",
        "analyse:ai": "phpstan analyse --no-progress --error-format=toon -c phpstan.neon",
        "test:ai": "phpunit --no-coverage --extension \"PeterFox\\PhpUnitToonResultPrinter\\ToonResultPrinterExtension\""
    },
    "scripts-descriptions": {
        "test": "Run the PHPUnit test suite",
        "test:coverage": "Run tests with code coverage report",
        "analyse": "Run PHPStan static analysis (level 8)",
        "lint": "Fix code style with Laravel Pint",
        "lint:check": "Check code style without making changes (CI-safe)",
        "check": "Check style, run static analysis, then run tests",
        "check:ai": "AI-optimised check: style, analysis, and tests with structured output",
        "lint:check:ai": "Check code style with agent-friendly output",
        "analyse:ai": "Run PHPStan with toon error format for AI agents",
        "test:ai": "Run PHPUnit with toon result printer for AI agents"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
